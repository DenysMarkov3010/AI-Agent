# === REQUIRED VARIABLES ===
#
# Jira base URL (no trailing slash)
# Example: https://yourcompany.atlassian.net
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_here

# OpenRouter API key (LLM)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional: comma-separated model IDs (first = primary; rest = fallback). If omitted, default is openai/gpt-oss-20b:free. See OPENROUTER.md
# OPENROUTER_MODELS=anthropic/claude-sonnet-4.5,openai/gpt-oss-20b:free

# === OPTIONAL VARIABLES ===
#
# Confluence base URL (if different from Jira).
# If not set, the agent uses JIRA_BASE_URL.
# CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net

# Jira project key (used mostly for batch mode)
JIRA_PROJECT_KEY=PROJ

# Required labels for validation (JSON array)
# Example: ["component/frontend", "domain/emergency"]
# REQUIRED_LABELS=["example-label-1", "example-label-2"]

# Label that marks change requests
# CHANGE_REQUEST_LABEL=change-request

# Folder where approved checklist CSV files are saved (not in the project folder).
# Default: %USERPROFILE%\OneDrive\Desktop\Checklists and Test cases (Windows)
# CHECKLIST_OUTPUT_DIR=C:\Users\YourName\OneDrive\Desktop\Checklists and Test cases

# Stage 1: what to generate (checklist = default, or testcases)
# GENERATE_MODE=checklist
# GENERATE_MODE=testcases
# Max LLM output tokens for GENERATE_MODE=testcases (default 12000 — higher = longer/more detailed cases)
# TEST_CASES_MAX_TOKENS=12000

# Two-step workflow flag:
# - false: generate checklist only and wait for your approval
# - true: generate CSV for approved items (if an APPROVED: comment exists)
CHECK_APPROVAL=false

# Optional: add a Jira label after BDD test cases are posted
# - false (recommended): do not add any "TC created" labels
# - true: add label "covered-by-tc"
ADD_TC_LABEL=false

# Documentation enrichment flags
ENABLE_CONFLUENCE_SEARCH=false
# When true, Confluence docs are read from links found in Jira requirements/description (not label-based search).
# Supported link format: .../wiki/spaces/.../pages/<PAGE_ID>/...
# ENABLE_RELATED_ISSUES_SEARCH=true
# Optional (single-run friendly): custom keywords/phrases for related Jira search (up to 30 issues returned).
# If set, these keywords are used instead of auto words from issue title.
# Separate by comma/semicolon/new line, e.g.:
# RELATED_ISSUES_KEYWORDS=payment status,verification dashboard,orders
# RELATED_ISSUES_KEYWORDS=

# Use test case files from project folder "Test cases" for analysis before checklist/test cases — single runs only (node agent-docs.js). Ignored when npm run batch (AGENT_BATCH_RUN).
ENABLE_TEST_CASES_ANALYSIS=false
# Optional: path to folder with .csv/.txt test case files (default: ./Test cases)
# TEST_CASES_FOLDER=./Test cases

# === UPDATED CSV FLOW (separate from default agent-docs flow) ===
# Source folder for CSV files that must be reworked against Jira requirements.
# UPDATED_TEST_CASES_FOLDER=./Updated test cases
# Optional specific input file in UPDATED_TEST_CASES_FOLDER (or absolute path).
# UPDATED_FLOW_INPUT_FILE=
# Flow mode: auto | testcases | checklist
# UPDATED_FLOW_MODE=auto

# === BATCH PROCESSING (daily processing for multiple issues) ===
# Batch only processes QA Sub-tasks whose summary matches Test design and status matches BATCH_QA_STATUS (default: QA IN PROGRESS).
# Override status if your Jira workflow uses a different name (must match JQL exactly).

# BATCH_QA_STATUS=QA IN PROGRESS
# BATCH_ISSUE_TYPE_QA_SUBTASK=QA Sub-task
# BATCH_TEST_DESIGN_SUMMARY_MATCH=Test design

# Day 1: create checklists (defaults are built from the vars above if BATCH_JQL_CHECKLIST is omitted)
# BATCH_JQL_CHECKLIST=project = PROJ AND issuetype = "QA Sub-task" AND summary ~ "Test design" AND status = "QA IN PROGRESS" ORDER BY updated DESC

# Day 2: APPROVED comment → CSV (same sub-task filters + comment ~ "APPROVED:")
# BATCH_JQL_APPROVAL=project = PROJ AND issuetype = "QA Sub-task" AND summary ~ "Test design" AND status = "QA IN PROGRESS" AND comment ~ "APPROVED:" ORDER BY updated DESC

# Legacy single JQL variable (optional; left for backward compatibility)
# BATCH_JQL=project = PROJ AND statusCategory = "In Progress" ORDER BY updated DESC

# Limits
BATCH_MAX_ISSUES=200

# Where to write batch-summary-YYYY-MM-DD.json (default: ./Batch Summary Archive)
# BATCH_SUMMARY_DIR=./Batch Summary Archive

# Skips
SKIP_WITH_CHECKLIST=true
SKIP_WITH_BDD=true

# === AZURE DEVOPS (read Test Plans / WIQL / work items in memory — see ADO_TEST_PLANS.md) ===
# ADO_ORG=your-org-name
# ADO_PROJECT=YourProjectName
# ADO_PAT=your_personal_access_token
# Default Test Plan id when ado:export-plan / ado:list-suites run without a CLI plan id (active / feature plan)
# ADO_ACTIVE_TEST_PLAN_ID=12345
# Optional: regression Test Plan id for coverage / gap analysis vs the active plan (read by tooling & prompts)
# ADO_REGRESSION_TEST_PLAN_ID=12346
# ADO_SERVER_URL=https://dev.azure.com
# ADO_API_VERSION=7.1-preview.1
# GET/POST cases in a suite use .../Plans/.../Suites/.../TestCase with api-version 7.1 by default (override if needed on Server)
# ADO_TESTPLAN_API_VERSION=7.1
# ADO_WIT_API_VERSION=7.1
# ADO_EXPORT_DIR=./ado-exports
# Optional: fixed output path for npm run ado:export-tag-csv (overrides Test cases/<tag>.csv; file is replaced each run)
# ADO_TAG_CSV_PATH=Test cases/my-export.csv
# Optional: WIQL tag filter when --tag / --tag= / --tag-file omitted (useful for tags with parentheses)
# ADO_EXPORT_TAG=Regression (smoke)

# After Jira approval (CHECK_APPROVAL=true): also create Azure DevOps Test Cases from the approved CSV (needs Work items Write on PAT)
# ADO_SYNC_APPROVED_CSV=true
# Automatic approval sync: Test Plan id for new cases MUST come from ADO_ACTIVE_TEST_PLAN_ID (above). ADO_SYNC_PLAN_ID and planId in ADO_SYNC_TEST_PLAN_URL are ignored for the plan.
# Suite: sync lists all suites in the plan, matches Jira key from CSV filename (e.g. approved-testcases-PROJ-123.csv) or issue key to suite name/path; ADO_SYNC_SUITE_ID / suite from URL = fallback if no match.
# ADO_SYNC_SUITE_MATCH_TITLE_ONLY=true   # only suites whose title contains the key (e.g. PROJ-123), not only a parent folder in the path
# ADO_SYNC_SUITE_MATCH_CSV_KEY=false
# ADO_SYNC_SUITE_LIST_VERBOSE=true   # log many suite id/path lines (uses ADO_SYNC_SUITE_LIST_MAX, default 50)
# ADO_SYNC_SUITE_LIST_MAX=50
# Bulk suite list uses GET .../test/Plans/{id}/suites with api-version 5.0 only (7.x is not used). On-prem / rare orgs: ADO_TEST_PLAN_BULK_API_VERSION=7.1
# Tree walk fallback (when bulk fails): limit parallel child-suite requests (default 4) if you see "fetch failed"
# ADO_SYNC_SUITE_TREE_CONCURRENCY=4
# Full Area Path in ADO, or prefix when CSV only has a leaf name (e.g. YourProject):
# ADO_AREA_PATH_PREFIX=YourOrg\YourProject
# ADO_DEFAULT_AREA_PATH=YourOrg\YourProject\QA
# Optional: add each new work item to a Test Plan suite — same numbers as in the browser
# (path YourOrg/YourProject = ADO_ORG / ADO_PROJECT; query params planId and suiteId):
#   .../_testPlans/define?planId=12686&suiteId=14213
# List plans: npm run ado:list-plans
# List suites: npm run ado:list-suites -- 12686
# ADO_SYNC_PLAN_ID=12686
# ADO_SYNC_SUITE_ID=14213
# Or paste the full URL from the address bar once (works with ADO_SYNC_APPROVED_CSV / sync):
# ADO_SYNC_TEST_PLAN_URL=https://dev.azure.com/YourOrg/YourProject/_testPlans/define?planId=12686&suiteId=14213
# Manual: npm run ado:sync-csv -- -p 12686 -s 14213 "path\to\file.csv"
# or: npm run ado:sync-csv -- --ado-url "https://..." "path\to\file.csv"
# Same with ADO_SYNC_JIRA_KEY=PROJ-123 or -j PROJ-123